PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/jeunes_db
# Obligatoire : aucun fallback n'est autorise pour des raisons de securite.
ADMIN_USERNAME=votre_identifiant_admin
ADMIN_PASSWORD=votre_mot_de_passe_tres_fort
# Une origine, ou plusieurs separees par des virgules (ex: https://monsite.com)
# En developpement (NODE_ENV != production), localhost et 127.0.0.1 sur n'importe quel port sont aussi acceptes.
FRONTEND_ORIGIN=http://localhost:3000

# Cloudflare Turnstile (anti-bot formulaire public) : laisser vide en dev si non utilise.
# Cle secrete pour verification serveur ; cote front : NEXT_PUBLIC_TURNSTILE_SITE_KEY dans frontend/.env
# TURNSTILE_SECRET_KEY=

# Au demarrage, le serveur applique automatiquement src/schema.sql (CREATE IF NOT EXISTS).
# Pour desactiver ce comportement : SKIP_AUTO_SCHEMA=1

# Donnees RDC pour validation serveur : apres modification de frontend/lib/provinces-data.ts ou kinshasa-quarters-data.ts
# npm run generate:rdc
