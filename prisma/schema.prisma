// Schéma Prisma aligné sur backend/src/schema.sql (table submissions).
// L'API Express utilise toujours `pg` ; Prisma sert surtout pour `prisma generate` / tooling.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id                  BigInt   @id @default(autoincrement())
  fullName            String   @map("full_name")
  phone               String
  email               String
  status              String
  ageRange            String   @map("age_range")
  gender              String
  province            String
  cityOrTerritory     String   @map("city_or_territory")
  communeOrSector     String   @map("commune_or_sector")
  quarter             String?
  consent             Boolean
  consentMethod       String   @map("consent_method")
  consentText         String   @map("consent_text")
  consentAcceptedAt   DateTime @default(now()) @map("consent_accepted_at") @db.Timestamptz(6)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("submissions")
}
